# Copy to secrets.sh and fill in values
# secrets.sh is gitignored

export ENCRYPTION_KEY=""       # openssl rand -base64 32
export RESEND_API_KEY=""       # From resend.com dashboard
export INTERNAL_SECRET=""      # openssl rand -hex 32
export BASE_URL=""             # e.g. https://yourdomain.com
export EMAIL_FROM=""           # e.g. "EFB Connector <noreply@yourdomain.com>"
